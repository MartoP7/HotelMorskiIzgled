@{
    ViewData["Title"] = "Начало";
}

<section class="hero-section">
    <div class="hero-overlay"></div>

    <div class="container hero-container">
        <div class="welcome-card" id="about-hotel">
            <div class="welcome-image">
                <img src="~/images/hotel.jpg" alt="Хотел Морски Изглед" />
            </div>

            <div class="welcome-text">
                @* <span class="welcome-badge">Добре дошли</span> *@
                <h1>Хотел „Морски Изглед“</h1>
                <p>
                    Насладете се на спокойствие, уют и красива морска атмосфера.
                    Хотелът предлага комфортни стаи, прекрасна локация до плажа
                    и приятна обстановка за вашата почивка. Тук ще откриете идеалното
                    място за отдих на първа линия, съчетаващо морски изглед, удобства
                    и модерен комфорт.
                </p>
                <a href="#amenities" class="welcome-btn">Напред</a>
            </div>
        </div>
    </div>
</section>
<section class="amenities-section" id="amenities">
    <div class="container">
        <div class="section-heading">
            <br>
            <br>
            <h2>Удобства</h2>
            <p>Всичко необходимо за една приятна и спокойна почивка.</p>
        </div>

        <div class="amenities-grid">
            <div class="amenity-item">
                <img src="~/images/icons/beach.png" alt="Плаж" />
                <span>Плаж</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/wifi.png" alt="Wi-Fi" />
                <span>Wi-Fi</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/food.png" alt="Ресторант" />
                <span>Ресторант</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/ac.png" alt="Климатик" />
                <span>Климатик</span>
            </div>

            <div class="amenity-item">
                <img src="~/images/icons/tv.png" alt="Телевизор" />
                <span>Телевизор</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/fridge.png" alt="Хладилник" />
                <span>Хладилник</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/lift.png" alt="Асансьор" />
                <span>Асансьор</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/guard.png" alt="Охрана" />
                <span>Охрана</span>
            </div>

            <div class="amenity-item">
                <img src="~/images/icons/towels.png" alt="Спално бельо" />
                <span>Спално бельо</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/store.png" alt="Магазин" />
                <span>Магазин</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/airport.png" alt="Трансфер" />
                <span>Трансфер</span>
            </div>
            <div class="amenity-item">
                <img src="~/images/icons/stairs.png" alt="Достъп" />
                <span>Достъп</span>
            </div>
        </div>
