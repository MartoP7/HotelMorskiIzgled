@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="auth-shell">
    <h1 class="auth-title">Създай акаунт в Морски Изглед</h1>
    <p class="auth-subtitle">Регистрирай се, за да резервираш по-бързо и удобно</p>

    <div class="row g-4 justify-content-center align-items-start">
        <div class="col-lg-6 col-md-9">
            <section class="auth-card">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <h2>Нова регистрация</h2>
                    <hr />
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true"  />
                        <label asp-for="Input.Email">Имейл</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true"  />
                        <label asp-for="Input.UserName">Потребителско име</label>
                        <span asp-validation-for="Input.UserName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.FirstName" class="form-control" aria-required="true"  />
                        <label asp-for="Input.FirstName">Име</label>
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.LastName" class="form-control" aria-required="true"  />
                        <label asp-for="Input.LastName">Фамилия</label>
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.PhoneNumber" class="form-control" aria-required="true"  />
                        <label asp-for="Input.PhoneNumber">Телефон</label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true"  />
                        <label asp-for="Input.Password">Парола</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true"  />
                        <label asp-for="Input.ConfirmPassword">Потвърди парола</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button id="registerSubmit" type="submit" class="btn btn-lg btn-primary">Регистрация</button>
                    </div>
                </form>
            </section>
        </div>

        <div class="col-lg-4 col-md-9">
            <section class="info-card">
                <h3>Предимства при регистрация</h3>
                <hr />
                <p>• По-бързо резервиране</p>
                <p>• Достъп до специални оферти</p>
                <p>• Преглед на история на резервации</p>
                <p>• По-лесна комуникация с хотела</p>

                @{
                    if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="external-login-buttons mt-4">
                            <div>
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name">
                                        Регистрация с @provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    }
                }
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}