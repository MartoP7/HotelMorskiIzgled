@page
@model LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="auth-page">
    <div class="auth-overlay"></div>

    <div class="auth-container">
        <div class="auth-card">
            <h1 class="auth-title">Добре дошли в Морски Изглед</h1>
            <p class="auth-subtitle">Влезте в профила си, за да управлявате своите резервации</p>

            <div class="split-auth">
                <div class="auth-left">
                    <section class="inner-auth-card">
                        <form id="account" method="post">
                            <h2>Вход в акаунт</h2>
                            <hr />
                            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true" />
                                <label asp-for="Input.UserName">Потребителско име</label>
                                <span asp-validation-for="Input.UserName" class="text-danger"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" />
                                <label asp-for="Input.Password">Парола</label>
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>

                            <div class="checkbox mb-3">
                                <label asp-for="Input.RememberMe" class="form-label">
                                    <input class="form-check-input" asp-for="Input.RememberMe" />
                                    Запомни ме
                                </label>
                            </div>

                            <div class="d-grid mb-3">
                                <button id="login-submit" type="submit" class="btn btn-lg btn-primary">Вход</button>
                            </div>

                            <div class="text-center">
                                <p><a id="forgot-password" asp-page="./ForgotPassword">Забравена парола?</a></p>
                                <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Създай нов акаунт</a></p>
                                <p><a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Изпрати потвърждение отново</a></p>
                            </div>
                        </form>
                    </section>
                </div>

                <div class="auth-right">
                    <section class="info-card">
                        <h3>Защо да изберете Морски Изглед?</h3>
                        <hr />
                        <p>• Луксозни стаи с морска панорама</p>
                        <p>• Бърза и лесна резервация</p>
                        <p>• Специални оферти за регистрирани потребители</p>
                        <p>• Уютна атмосфера и отлично обслужване</p>

                        @{
                            if ((Model.ExternalLogins?.Count ?? 0) > 0)
                            {
                                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="external-login-buttons mt-4">
                                    <div>
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit" class="btn btn-primary mb-2" name="provider" value="@provider.Name">
                                                Вход с @provider.DisplayName
                                            </button>
                                        }
                                    </div>
                                </form>
                            }
                        }
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>


<footer class="site-footer">
    <div class="footer-overlay"></div>

    <div class="container footer-content">
        <div class="footer-grid">

            <!-- Контакти -->
            <div class="footer-section">
                <h3>Контакти</h3>
                <p>📞 +359 888 123 456</p>
                <p>📧 info@morskigled.bg</p>
                <p>📍 Несебър, България</p>
            </div>

            <!-- Социални -->
            <div class="footer-section">
                <h3>Социални мрежи</h3>

                <a href="#" class="social-link">
                    <img src="~/images/icons/facebook.png" />
                    <span>Facebook</span>
                </a>

                <a href="#" class="social-link">
                    <img src="~/images/icons/instagram.png" />
                    <span>Instagram</span>
                </a>

                <a href="#" class="social-link">
                    <img src="~/images/icons/tiktok.png" />
                    <span>TikTok</span>
                </a>
            </div>

            <!-- Навигация -->
            <div class="footer-section">
                <h3>Навигация</h3>
                <a asp-controller="Home" asp-action="Index">Начало</a>
                <a href="#hotel-plan">Схема</a>
                <a href="#about-hotel">За нас</a>
                <a asp-controller="Reservations" asp-action="Create">Резервация</a>
            </div>

        </div>

        <div class="footer-bottom">
            © 2026 Морски Изглед. Всички права запазени.
        </div>
    </div>
</footer>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}