@page
@model LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="auth-shell">
    <h1 class="auth-title">Добре дошли в Морски Изглед</h1>
    <p class="auth-subtitle">Влезте в профила си, за да управлявате своите резервации</p>

    <div class="row g-4 justify-content-center align-items-start">
        <div class="col-lg-5 col-md-8">
            <section class="auth-card">
                <form id="account" method="post">
                    <h2>Вход в акаунт</h2>
                    <hr />
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true"  />
                        <label asp-for="Input.UserName">Потребителско име</label>
                        <span asp-validation-for="Input.UserName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true"  />
                        <label asp-for="Input.Password">Парола</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="checkbox mb-3">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            Запомни ме
                        </label>
                    </div>

                    <div class="d-grid mb-3">
                        <button id="login-submit" type="submit" class="btn btn-lg btn-primary">Вход</button>
                    </div>

                    <div class="text-center">
                        <p><a id="forgot-password" asp-page="./ForgotPassword">Забравена парола?</a></p>
                        <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Създай нов акаунт</a></p>
                        <p><a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Изпрати потвърждение отново</a></p>
                    </div>
                </form>
            </section>
        </div>

        <div class="col-lg-5 col-md-8">
            <section class="info-card">
                <h3>Защо да изберете Морски Изглед?</h3>
                <hr />
                <p>• Луксозни стаи с морска панорама</p>
                <p>• Бърза и лесна резервация</p>
                <p>• Специални оферти за регистрирани потребители</p>
                <p>• Уютна атмосфера и отлично обслужване</p>

                @{
                    if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="external-login-buttons mt-4">
                            <div>
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name">
                                        Вход с @provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    }
                }
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}